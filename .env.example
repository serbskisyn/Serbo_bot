# ─────────────────────────────────────────────
#  Serbo Bot — Environment Variables Template
#  Kopiere diese Datei: cp .env.example .env
# ─────────────────────────────────────────────


# ── Pflichtfelder ─────────────────────────────
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=


# ── LLM ──────────────────────────────────────
OPENROUTER_MODEL=openai/gpt-4o-mini
BOT_NAME=MeinAgent


# ── API Keys ──────────────────────────────────
TAVILY_API_KEY=
GNEWS_API_KEY=


# ── Zugriffskontrolle ─────────────────────────
# Kommagetrennte Telegram User-IDs (kein Leerzeichen)
ALLOWED_USER_IDS=

# Telegram Chat-ID für System-Alerts (Feed-Health etc.)
# Fallback: erster Eintrag aus ALLOWED_USER_IDS
ADMIN_CHAT_ID=


# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60


# ── News ──────────────────────────────────────
# Clubs für den automatischen Background-Fetch (kommagetrennt)
NEWS_FAVORITE_CLUBS=Borussia Dortmund,Dynamo Dresden

# Artikel-TTL im Cache
NEWS_CACHE_MAX_AGE_HOURS=48

# Background-Refresh-Interval: base ± jitter Minuten
NEWS_SCHEDULER_BASE_MINUTES=45
NEWS_SCHEDULER_JITTER_MINUTES=15

# Ab wann wird "gecacht vor X min" angezeigt
NEWS_STALE_LABEL_HOURS=4


# ── Täglicher News-Push ───────────────────────
# Uhrzeit (CEST): 06:30 = 06 / 30
NEWS_DAILY_PUSH_HOUR=6
NEWS_DAILY_PUSH_MINUTE=30

# Empfänger des täglichen Push (kommagetrennt)
# Leer lassen = alle ALLOWED_USER_IDS bekommen den Push
NEWS_DAILY_PUSH_USER_IDS=


# ── Google Sheets / Dienstplan ────────────────
# Pfad zur Google Cloud Service Account JSON-Datei
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

SCHEDULE_URLAUB_SHEET_ID=
SCHEDULE_WUNSCH_SHEET_ID=
SCHEDULE_KRANK_SHEET_ID=
SCHEDULE_OUTPUT_SHEET_ID=


# ── Brave Search (Tavily-Fallback) ────────────
# Optional: Brave Search API Key (https://api.search.brave.com)
BRAVE_API_KEY=


# ── Text-to-Speech ────────────────────────────
# Sprachantworten bei Voice-Nachrichten (edge-tts, kostenlos)
TTS_ENABLED=true
# Stimme: de-DE-KatjaNeural, de-DE-ConradNeural, de-AT-JonasNeural, ...
TTS_VOICE=de-DE-KatjaNeural


# ── Session Summaries ─────────────────────────
# Tägliche Gesprächszusammenfassung (Uhrzeit Europe/Berlin)
SESSION_SUMMARY_HOUR=23
SESSION_SUMMARY_MINUTE=0
# Mindestanzahl Nachrichten bevor eine Zusammenfassung erstellt wird
SESSION_SUMMARY_MIN_MESSAGES=6


# ── Health Check ──────────────────────────────
# Täglicher System-Status-Report (Uhrzeit Europe/Berlin)
HEALTH_CHECK_HOUR=7
HEALTH_CHECK_MINUTE=0


# ── Sonstiges ─────────────────────────────────
LOG_LEVEL=INFO
