# Strava Session Cookie
# Einmalig: python kudos_bot.py --set-session <wert>
# (Cookie aus Browser: F12 → Application → Cookies → _strava4_session)
STRAVA_SESSION_COOKIE=

# Telegram – für Morgen-Benachrichtigung nach dem Kudos-Lauf
# Bot-Token: @BotFather → /newbot oder bestehenden Token einfügen
TELEGRAM_BOT_TOKEN=
# Chat-ID: @userinfobot schreiben, gibt deine ID zurück
TELEGRAM_CHAT_ID=
